# PostgreSQL defaults for local Docker and debug usage.
POSTGRES_DB="superhrd"
POSTGRES_USER="superhrd"
POSTGRES_PASSWORD="superhrd_dev_password"
POSTGRES_PORT=5432

# App connection string. For local app outside Docker, point to localhost.
DATABASE_URL="postgresql://superhrd:superhrd_dev_password@localhost:5432/superhrd?schema=public"

# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET="generate-a-random-secret-here"
AUTH_TRUST_HOST="true"

# Public URL that users open in the browser.
NEXTAUTH_URL="https://superhrd.example.com"
APP_URL="https://superhrd.example.com"

# Base URL n8n (and other in-Docker callers) use to reach SuperHRD callbacks.
# On the same Docker bridge: http://superhrd:3000 (bypasses Cloudflare Tunnel / reverse proxy).
# Leave unset to fall back to APP_URL (works when n8n is external and reaches the public URL).
APP_INTERNAL_URL="http://superhrd:3000"

# Use an HTTPS URL if n8n is external.
# If n8n runs on the same Docker network, use: http://n8n:5678/webhook/pdf
# If n8n runs on the host machine, use: http://host.docker.internal:5678/webhook/pdf
N8N_WEBHOOK_URL="https://your-n8n-instance.com/webhook/your-webhook-id"
N8N_CALLBACK_SECRET="generate-a-random-secret-here"

# Midtrans QRIS payments. Use sandbox keys for development, production keys for live.
MIDTRANS_MERCHANT_ID="Gxxxxxxxxx"
MIDTRANS_CLIENT_KEY="SB-Mid-client-xxxxxxxxxxxxxxxx"
MIDTRANS_SERVER_KEY="SB-Mid-server-xxxxxxxxxxxxxxxx"
MIDTRANS_IS_PRODUCTION="false"
# Optional override if Midtrans must call a different public URL than APP_URL.
# MIDTRANS_NOTIFICATION_URL="https://superhrd.example.com/api/payments/midtrans/notification"

# Optional top-up rate limit override. Production defaults to 5/hour, development defaults to 50/hour.
# TOPUP_RATE_LIMIT_MAX_REQUESTS=50

# Optional host port for docker-compose.yml.
SUPERHRD_PORT=3000
