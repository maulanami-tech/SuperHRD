generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                      String                   @id @default(cuid())
  name                    String
  email                   String                   @unique
  passwordHash            String
  emailVerified           DateTime?
  creditBalance           Int                      @default(0)
  dailyQuotaUsed          Int                      @default(0)
  lastQuotaDate           String                   @default("")
  isAdmin                 Boolean                  @default(false)
  passwordChangedAt       DateTime?
  createdAt               DateTime                 @default(now())
  candidates              Candidate[]
  emailVerificationTokens EmailVerificationToken[]
  passwordResetTokens     PasswordResetToken[]
  promoRedemptions        PromoRedemption[]
  transactions            Transaction[]
  topupRequests           TopupRequest[]
  uploadBatches           UploadBatch[]
  jobPositions            JobPosition[]
  pipelineStages          PipelineStage[]
  candidateFieldDefinitions CandidateFieldDefinition[]
}

model EmailVerificationToken {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([userId, expiresAt])
}

model PasswordResetToken {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([userId, expiresAt])
}

model Candidate {
  id              String           @id @default(cuid())
  name            String
  email           String?
  fileName        String
  filePath        String
  status          String           @default("pending")
  overallScore    Float?
  posisi          String?
  kriteria        String?
  prompt          String?
  n8nRunId        String?          @unique
  idempotencyKey  String?          @unique
  creditSource    String?
  batchId         String?
  batch           UploadBatch?     @relation(fields: [batchId], references: [id])
  jobPositionId   String?
  jobPosition     JobPosition?     @relation(fields: [jobPositionId], references: [id], onDelete: SetNull)
  pipelineStageId String?
  pipelineStage   PipelineStage?   @relation(fields: [pipelineStageId], references: [id], onDelete: SetNull)
  fieldValues     CandidateFieldValue[]
  notes           String?
  submittedBy     String
  submittedById   String
  submittedByUser User             @relation(fields: [submittedById], references: [id])
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  screeningResult ScreeningResult?

  @@index([batchId])
  @@index([jobPositionId])
  @@index([pipelineStageId])
}

model PipelineStage {
  id         String      @id @default(cuid())
  ownerId    String
  owner      User        @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  name       String
  color      String      @default("slate")
  order      Int
  isTerminal Boolean     @default(false)
  createdAt  DateTime    @default(now())
  candidates Candidate[]

  @@index([ownerId, order])
}

enum CandidateFieldType {
  number
  currency
  text
  date
}

model CandidateFieldDefinition {
  id        String                @id @default(cuid())
  ownerId   String
  owner     User                  @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  label     String
  type      CandidateFieldType
  order     Int
  createdAt DateTime              @default(now())
  values    CandidateFieldValue[]

  @@index([ownerId, order])
}

model CandidateFieldValue {
  id                String                   @id @default(cuid())
  candidateId       String
  candidate         Candidate                @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  fieldDefinitionId String
  fieldDefinition   CandidateFieldDefinition @relation(fields: [fieldDefinitionId], references: [id], onDelete: Cascade)
  valueNumber       Float?
  valueText         String?
  valueDate         DateTime?

  @@unique([candidateId, fieldDefinitionId])
  @@index([fieldDefinitionId])
}

model UploadBatch {
  id            String      @id @default(cuid())
  submittedById String
  submittedBy   User        @relation(fields: [submittedById], references: [id])
  posisi        String
  kriteria      String
  prompt        String
  jobPositionId String?
  jobPosition   JobPosition? @relation(fields: [jobPositionId], references: [id], onDelete: SetNull)
  totalFiles    Int
  acceptedFiles Int
  rejectedFiles Int
  status        String      @default("processing")
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  candidates    Candidate[]

  @@index([submittedById, createdAt])
  @@index([jobPositionId])
}

model ScreeningResult {
  id           String    @id @default(cuid())
  candidateId  String    @unique
  candidate    Candidate @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  overallScore Float
  summary      String
  criteria     String
  rawResponse  String?
  scoredAt     DateTime  @default(now())
}

enum TransactionType {
  topup_qris
  topup_stripe
  deduct_screening
  generate_prompt
  admin_adjustment
  daily_quota
  refund
  promo_bonus
}

enum PromoCodeType {
  registration
  topup
  any
}

model PromoCode {
  id              String            @id @default(cuid())
  code            String            @unique
  type            PromoCodeType     @default(registration)
  creditAmount    Int               @default(0)
  discountPercent Int?
  bonusPercent    Int?
  maxRedemptions  Int?
  expiresAt       DateTime?
  active          Boolean           @default(true)
  createdBy       String
  createdAt       DateTime          @default(now())
  redemptions     PromoRedemption[]
  topupRequests   TopupRequest[]

  @@index([active, expiresAt])
}

enum PromoRedemptionStatus {
  pending
  claimed
}

model PromoRedemption {
  id           String                @id @default(cuid())
  codeId       String
  code         PromoCode             @relation(fields: [codeId], references: [id], onDelete: Cascade)
  userId       String
  user         User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  creditAmount Int
  context      String                @default("registration")
  status       PromoRedemptionStatus @default(pending)
  createdAt    DateTime              @default(now())
  claimedAt    DateTime?

  @@unique([userId, codeId])
  @@index([codeId, status])
}

model Transaction {
  id           String          @id @default(cuid())
  userId       String
  user         User            @relation(fields: [userId], references: [id])
  type         TransactionType
  creditDelta  Int
  balanceAfter Int
  amountIdr    Int?
  description  String
  metadata     String?
  createdAt    DateTime        @default(now())

  @@index([userId, createdAt])
}

enum PaymentMethod {
  qris
  stripe
}

enum TopupStatus {
  pending
  approved
  rejected
  expired
}

model TopupRequest {
  id                    String        @id @default(cuid())
  userId                String
  user                  User          @relation(fields: [userId], references: [id])
  amountIdr             Int
  creditAmount          Int
  paymentMethod         PaymentMethod
  status                TopupStatus   @default(pending)
  proofImageUrl         String?
  notes                 String?
  processedBy           String?
  processedAt           DateTime?
  expiresAt             DateTime      @default(now())
  createdAt             DateTime      @default(now())
  paymentProvider       String        @default("manual")
  providerOrderId       String?       @unique
  providerTransactionId String?
  providerStatus        String?
  providerFraudStatus   String?
  qrCodeUrl             String?
  qrString              String?
  providerPayload       String?
  promoCodeId           String?
  promoCode             PromoCode?    @relation(fields: [promoCodeId], references: [id], onDelete: SetNull)

  @@index([userId, status])
  @@index([status, createdAt])
  @@index([paymentProvider, providerStatus])
}

enum JobPositionStatus {
  open
  closed
  archived
}

model JobPosition {
  id          String            @id @default(cuid())
  ownerId     String
  owner       User              @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  title       String
  description String?
  kriteria    String
  prompt      String
  status      JobPositionStatus @default(open)
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  candidates  Candidate[]
  batches     UploadBatch[]

  @@index([ownerId, status])
}

model RateLimit {
  id          String   @id @default(cuid())
  key         String   @unique
  count       Int      @default(1)
  windowStart DateTime @default(now())
  createdAt   DateTime @default(now())

  @@index([key, windowStart])
}
